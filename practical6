<!DOCTYPE html>
<html>
<head>
    <title>Structured Webpage with CSS</title>

    <link rel="stylesheet" href="style.css">

    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f4f4;
        }
        header, footer {
            background-color: #333;
            color: white;
            text-align: center;
            padding: 15px;
        }
        article {
            background-color: white;
            padding: 20px;
            margin: 10px;
        }
        aside {
            background-color: #ddd;
            padding: 15px;
            margin: 10px;
        }
        table {
            width: 100%;
            border-collapse: collapse;
        }
        table, th, td {
            border: 1px solid black;
        }
        th, td {
            padding: 10px;
            text-align: center;
        }
    </style>
</head>

<body>

<header>
    <h1 style="color: yellow;">Student Information Page</h1>
</header>

<article>
    <h2>Student Marksheet</h2>

    <table>
        <tr>
            <th>Name</th>
            <th>ERP ID</th>
            <th>Marks</th>
            <th>Grace</th>
            <th>Total Marks</th>
        </tr>
        <tr>
            <td>Ayush Kumar</td>
            <td>10341</td>
            <td>450</td>
            <td>20</td>
            <td>470</td>
        </tr>
        <tr>
            <td>Ayush Kumar</td>
            <td>10343</td>
            <td>430</td>
            <td>15</td>
            <td>445</td>
        </tr>
    </table>
</article>

<aside>
    <h3>Useful Links</h3>
    <ul>
        <li><a href="https://www.google.com">Google</a></li>
        <li><a href="https://www.wikipedia.org">Wikipedia</a></li>
    </ul>

    <h3>Subjects</h3>
    <ol>
        <li>Mathematics</li>
        <li>Computer Science</li>
        <li>Physics</li>
    </ol>
</aside>

<footer>
    <p>© 2025 Ayush Kumar</p>
</footer>

</body>
</html>